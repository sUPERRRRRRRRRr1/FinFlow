# ─────────────────────────────────────────────────────────────
# FinFlow environment — ทุกอย่างเป็น OPTIONAL
# แอปรันได้เต็มรูปแบบในโหมดเดโมโดยไม่ต้องใส่ค่าใดเลย
# ใส่เมื่อต้องการต่อ Gmail / Gemini ของจริงเท่านั้น
# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่า
# ─────────────────────────────────────────────────────────────

# พอร์ตของ backend (ดีฟอลต์ 4000)
PORT=4000

# Google Gemini API key — โมเดลหลัก (Gemini flash-lite) สำหรับ OCR สลิป + งาน text + จัดหมวดอัตโนมัติ
# ไม่ใส่ = ถอยไปใช้ Groq (ถ้าตั้ง) แล้วจึง Tesseract/rule-based — แอปยังทำงานครบ
GEMINI_API_KEY=
# โมเดลเริ่มต้น (ปรับได้) — ใช้ทั้งงาน text และ OCR สลิป (vision)
GEMINI_MODEL=gemini-3.1-flash-lite

# Groq (groq.com) API key — ตัวสำรองของงาน text + OCR สลิป (ทำงานเมื่อ Gemini ไม่พร้อม/ไม่ได้ตั้ง key)
# หมายเหตุ: Groq (key ขึ้นต้น gsk_) ไม่ใช่ xAI Grok (key ขึ้นต้น xai-) — คนละเจ้ากัน
GROQ_API_KEY=
# โมเดลเริ่มต้น (ปรับได้) — ดูรายชื่อล่าสุดที่ https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile
# โมเดล vision (multimodal) สำหรับ OCR สลิป — Llama 4
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# (ปกติไม่ต้องแก้) endpoint แบบ OpenAI-compatible — ชี้ไป provider เจ้าอื่น (เช่น xAI Grok) ได้
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Gmail OAuth (อ่านอย่างเดียว: scope gmail.readonly) — เปิดใช้การดึงเมลจริง
# สร้างได้ที่ https://console.cloud.google.com → OAuth client (Web application)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# (ออปชัน) ป้ายกำกับ Gmail ที่คุณ forward "สลิป" มาเก็บไว้ เช่น FinFlow
# ระบบจะดึงรูปสลิปจากเมลธนาคาร + เมลที่มีป้ายนี้ มา OCR ให้ (สลิปเป็นรูปต้องมี GEMINI_API_KEY)
GMAIL_SLIP_LABEL=

# (ออปชัน) รหัสเปิด PDF statement ที่ใส่รหัส เช่น K-eDocument ของ KBank (ไฟล์ STM_SA*.pdf)
# ใส่แล้ว server จะถอดรหัส + อ่านรายการเดินบัญชีย้อนหลังจากอีเมลให้อัตโนมัติ
STATEMENT_PDF_PASSWORD=

# โหมดเดโม: บังคับ seed ข้อมูลตัวอย่างเมื่อฐานข้อมูลว่าง (1 = เปิด)
SEED_DEMO=1
